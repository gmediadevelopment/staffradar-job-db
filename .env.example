# Job Database Server
PORT=4500
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://staffradar:YOUR_DB_PASSWORD@db:5432/staffradar_jobs
DB_PASSWORD=YOUR_DB_PASSWORD

# API Keys
BA_API_KEY=jobboerse-jobsuche
ADZUNA_APP_ID=YOUR_APP_ID
ADZUNA_API_KEY=YOUR_API_KEY
