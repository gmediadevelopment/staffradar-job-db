CAREERJET_AFFID=YOUR_AFFID

# SerpAPI (optional)
SERPAPI_KEY=

# StaffRadar API Auth
API_SECRET=YOUR_SECRET

# Admin Dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=YOUR_PASSWORD
